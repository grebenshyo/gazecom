# gazeCOM configuration - copy to .env and adjust per machine.
# .env is gitignored.

# ComfyUI server — host:port of a running ComfyUI. This is the ONLY
# ComfyUI setting: gazeCOM talks to it entirely over the ComfyUI API, so
# ComfyUI can run anywhere reachable. If it's not on this machine, start
# ComfyUI with --listen and point this at its LAN/remote address.
COMFY_HOST=127.0.0.1:8188

# Ollama server - used by LLM prompt enhancement. gazeCOM talks to Ollama
# directly over its local HTTP API; no ComfyUI LLM workflow is required.
OLLAMA_HOST=127.0.0.1:11434
# Keep the selected Ollama LLM loaded after prompt enhancement.
# false frees shared GPU memory for Comfy/Flux; true avoids reload latency
# when Ollama runs on a separate machine (for example a Mac).
OLLAMA_KEEP_MODEL_LOADED=false

# gazeCOM asset folders (relative to repo root or absolute)
WORKFLOWS_DIR=../workflows
# Optional second workflow root. User files override bundled files with the
# same category/name. Packaged builds configure this automatically.
# USER_WORKFLOWS_DIR=/path/to/user/workflows
IMAGES_DIR=../images

# Backend HTTP server
# Bind locally by default. Use 0.0.0.0 only when you intentionally want other
# devices on the LAN to reach gazeCOM.
HOST=127.0.0.1
PORT=8000

# CORS - comma-separated origins used by the Vite development frontend.
# Add explicit LAN origins if you intentionally expose the development server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Generation timeouts (seconds)
GENERATE_TIMEOUT=300
LLM_TIMEOUT=60
